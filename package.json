{
  "name": "scopra",
  "version": "0.0.1",
  "description": "Developer-first TypeScript policy enforcement for AI applications.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun run clean && tsc -p tsconfig.build.json",
    "check": "bun run typecheck && biome check .",
    "ci": "bun run check && bun test && bun run build && bun run pack:dry-run",
    "clean": "rm -rf dist",
    "format": "biome format --write .",
    "pack:dry-run": "bun run build && npm pack --dry-run",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "bun run check && bun test && bun run build"
  },
  "keywords": [
    "agents",
    "ai",
    "ai-safety",
    "guardrails",
    "llm",
    "policy",
    "prompt-injection",
    "security",
    "sdk",
    "typescript"
  ],
  "homepage": "https://github.com/MrLightful/scopra#readme",
  "bugs": {
    "url": "https://github.com/MrLightful/scopra/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrLightful/scopra.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.7",
    "@changesets/cli": "^2.31.0",
    "@tanstack/ai": "^0.38.0",
    "@types/bun": "^1.3.2",
    "ai": "^7.0.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@tanstack/ai": "^0.38.0",
    "ai": "^7.0.4"
  },
  "peerDependenciesMeta": {
    "@tanstack/ai": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
